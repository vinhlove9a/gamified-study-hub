# =============================================================================
# Production env template for the single-host Docker Compose deploy (EC2).
# Copy to `.env` on the server and fill in the secrets:
#   cp .env.prod.example .env  &&  nano .env
# `.env` is gitignored — never commit real secrets.
# =============================================================================

# --- App ---------------------------------------------------------------------
APP_ENV=production
APP_NAME=Gamified Study Hub

# --- Backend -----------------------------------------------------------------
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=prod
# Public origin of the site. Same-origin via nginx so CORS is not triggered for
# the browser, but keep it accurate for safety. Use https://<domain> once TLS is on.
FRONTEND_ORIGIN=https://aquvix.site
# REQUIRED. Generate a strong value, e.g.:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_min_32_chars_use_openssl_rand_base64_48
# Short-lived access token (cookie gsh_at); refresh handled by the refresh cookie.
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=30
# Auth cookies. Domain covers apex + www; Secure requires HTTPS (true in prod).
COOKIE_DOMAIN=aquvix.site
COOKIE_SECURE=true
COOKIE_SAMESITE=Lax

# --- Frontend ----------------------------------------------------------------
# Leave EMPTY so the SPA uses same-origin relative paths (/api/v1/...) proxied
# by nginx. Do NOT set http://localhost:... — a remote browser cannot reach it
# and authApi already prefixes /api/v1, which would double the /api segment.
VITE_API_BASE_URL=

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=gamified_study_hub
POSTGRES_USER=gsh_user
# REQUIRED. Use a strong password, e.g.:  openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# --- Redis -------------------------------------------------------------------
# Used for login rate-limiting, account lockout, and refresh-token rotation.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Mail (SMTP) -------------------------------------------------------------
# Leave MAIL_HOST empty to disable sending (links are logged instead).
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@aquvix.site
# Base URL for verify/reset links in emails (defaults to FRONTEND_ORIGIN).
MAIL_BASE_URL=https://aquvix.site

# --- Nginx (public entrypoint) ----------------------------------------------
NGINX_PORT=80
