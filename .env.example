# App
APP_ENV=local
APP_NAME=Gamified Study Hub

# Backend
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=dev
FRONTEND_ORIGIN=http://localhost,http://localhost:5173
JWT_SECRET=change-this-local-development-secret-at-least-32-characters
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=60

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=gamified_study_hub
POSTGRES_USER=gsh_user
POSTGRES_PASSWORD=gsh_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Google OAuth2 (social login)
GOOGLE_CLIENT_ID=dummy-client-id-for-local-dev
GOOGLE_CLIENT_SECRET=dummy-client-secret-for-local-dev

